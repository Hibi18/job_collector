<h1 class="mb-4">求人情報一覧</h1>

<!-- 検索フォーム -->
<form method="get" action="<%= jobs_path %>" class="mb-4">
  <div class="form-row align-items-center">
    <div class="col-auto">
      <input type="text" name="search" value="<%= params[:search] %>" placeholder="職種や勤務地で検索" class="form-control mb-2">
    </div>
    <div class="col-auto">
      <select name="location" class="form-control mb-2">
        <option value="">勤務地を選択</option>
        <% Job.distinct.pluck(:location).each do |loc| %>
          <option value="<%= loc %>" <%= "selected" if params[:location] == loc %>><%= loc %></option>
        <% end %>
      </select>
    </div>
    <div class="col-auto">
      <select name="min_salary" class="form-control mb-2">
        <option value="">最低給与を選択</option>
        <option value="300">300万円</option>
        <option value="400">400万円</option>
        <option value="500">500万円</option>
      </select>
    </div>
    <div class="col-auto">
      <select name="max_salary" class="form-control mb-2">
        <option value="">最高給与を選択</option>
        <option value="500">500万円</option>
        <option value="600">600万円</option>
        <option value="700">700万円</option>
      </select>
    </div>
    <div class="col-auto">
      <button type="submit" class="btn btn-primary mb-2">検索</button>
      <%= link_to "リセット", jobs_path, class: "btn btn-secondary mb-2" %>
    </div>
  </div>
</form>

<!-- 検索結果 -->
<% if @jobs.empty? %>
  <div class="alert alert-danger">該当する求人情報は見つかりませんでした。</div>
<% else %>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>職種</th>
        <th>勤務地</th>
        <th>給与</th>
        <th>会社名</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @jobs.each do |job| %>
        <tr>
          <td><%= job.title %></td>
          <td><%= job.location %></td>
          <td><%= job.salary %></td>
          <td><%= job.company %></td>
          <td>
            <%= link_to "詳細", job_path(job), class: "btn btn-link" %>
            <%= link_to "編集", edit_job_path(job), class: "btn btn-link" %>
            <%= link_to "削除", job_path(job), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-link text-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <!-- ページネーション -->
  <div class="pagination justify-content-center mt-4">
    <%= paginate @jobs %>
  </div>
<% end %>

<%= link_to "新しい求人情報を作成", new_job_path, class: "btn btn-success mt-4" %>
